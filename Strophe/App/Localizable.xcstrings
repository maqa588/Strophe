    "crf_value_explanation" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعني انخفاض CRF جودة أعلى، وتصديرًا أبطأ، وملفًا أكبر."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lower CRF means higher quality, slower export, and larger file."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CRF値が低いほど高品質になり、エクスポートが遅くなり、ファイルが大きくなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CRF 값이 낮을수록 화질이 높아지고 내보내기가 느려지며 파일이 커집니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数字越小画质越高，导出速度也会相应变慢，同时文件会变大。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "數字越小畫質越高，匯出速度也會相應变慢，同時檔案會变大。"
          }
        }
      }
    },
