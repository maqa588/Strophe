    "Drop a video or audio file here, or click to import" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بإسقاط ملف فيديو أو صوت هنا، أو انقر للاستيراد"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ここにビデオまたはオーディオファイルをドロップするか、クリックしてインポートします"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기에 비디오 또는 오디오 파일을 드롭하거나 클릭하여 가져옵니다"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
