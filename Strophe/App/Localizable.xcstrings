    "multipass_videotoolbox_explanation" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إيقاف افتراضي. يقوم VideoToolbox بتحليل تمريرات متعددة للحركات المنخفضة أو معدلات البت المستهدفة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Default off. VideoToolbox analyzes multiple passes for low-motion or target bitrates."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デフォルトはオフ。VideoToolboxは低モーションまたはターゲットビットレートのためにマルチパス分析を行います。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기본값은 비활성화. VideoToolbox는 저움직임 또는 대상 비트레이트를 위해 멀티패스 분석을 수행합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认关闭。开启后会让 VideoToolbox 在支持时进行多遍分析，导出更慢，但低运动画面和目标码率模式通常更容易压出更小体积。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "預設關閉。開啟後會讓 VideoToolbox 在支援時進行多遍分析，匯出更慢，但低運動畫面和目標碼率模式通常更容易壓出更小體積。"
          }
        }
      }
    },
