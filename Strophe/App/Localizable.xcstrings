    "disable_vad_explanation" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند تعطيل VAD، سيتم تقسيم الصوت إلى مقاطع متساوية بطول 20 ثانية لضمان استقرار واستمرارية التعرف على الصوت الطويل."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When VAD is disabled, audio is divided into uniform 20-second segments to ensure stable and continuous long audio transcription."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VADを無効にすると、長時間のオーディオを安定して連続的に認識できるように、オーディオが20秒ごとに均等に分割されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VAD를 비활성화하면 오디오가 20초 단위로 균일하게 분할되어 긴 오디오의 안정적이고 연속적인 음성 인식을 수행합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭 VAD 后，音频将按每段 20 秒均匀切分，以实现长音频的稳定连续识别。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "關閉 VAD 後，音訊將按每段 20 秒均勻切分，以實現長音訊的穩定連續識別。"
          }
        }
      }
    },
