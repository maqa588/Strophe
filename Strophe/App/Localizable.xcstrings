    "Paste your script below. Each line becomes one subtitle segment." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ألصق النص أدناه. كل سطر يصبح مقطع ترجمة واحد."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下にスクリプトを貼り付けてください。各行が1つの字幕セグメントになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아래에 스크립트를 붙여넣으세요. 각 줄이 하나의 자막 세그먼트가 됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在下方粘贴您的文稿。每一行将生成一段字幕。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在下方貼上您的文稿。每一行將生成一段字幕。"
          }
        }
      }
    },
    "Paste your script to start marking timestamps." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
