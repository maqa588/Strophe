    "prores_coding_explanation" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم ProRes معلمات ترميز متوسطة ثابتة من Apple، مناسبة للتحرير أو الأرشفة؛ يعتمد معدل البت على المواصفات والحجم."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ProRes uses Apple's fixed intermediate coding parameters, suitable for editing or archiving; bitrate depends on specs and size."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ProResはAppleの固定中間エンコーディングパラメータを使用し、編集や高品質アーカイブに適しています。ビットレートは仕様とサイズによります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ProRes는 Apple의 고정 중간 인코딩 매개변수를 사용하므로 편집이나 보관에 적합합니다. 비트레이트는 사양과 해상도에 따릅니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ProRes 使用 Apple 固定的中间片编码参数，适合继续剪辑或高质量归档；码率由 ProRes 规格和画面尺寸决定。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ProRes 使用 Apple 固定的中間片編碼參數，適合繼續剪輯或高品質歸檔；碼率由 ProRes 規格和畫面尺寸決定。"
          }
        }
      }
    },
