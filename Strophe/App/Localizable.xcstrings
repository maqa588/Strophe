    "the_current_dependency_does_not" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التبعية الحالية لا توفر واجهة استدلال CoreML ForcedAligner حاليًا؛ يمكن تنزيله كاحتياطي، ولكن يرجى اختيار MLX 4-bit للتوليد الفعلي."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The current dependency does not yet provide the CoreML ForcedAligner inference interface; you can download it as a backup, but please select MLX 4-bit for actual generation."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在の依存関係はまだCoreML ForcedAligner推論インターフェースを提供していません。バックアップとしてダウンロードできますが、実際の生成にはまずMLX 4-bitを選択してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 종속성은 아직 CoreML ForcedAligner 추론 인터페이스를 제공하지 않습니다. 백업으로 다운로드할 수 있지만 실제 생성 시에는 MLX 4-bit를 선택해 주십시오."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当前依赖暂未提供 CoreML ForcedAligner 推理接口；可下载备用，实际生成请先选 MLX 4-bit。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當前依賴暫未提供 CoreML ForcedAligner 推理介面；可下載備用，實際生成請先選 MLX 4-bit。"
          }
        }
      }
    },
