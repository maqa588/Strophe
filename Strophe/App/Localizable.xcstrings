    "note_clearing_cache_is_completely" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ملاحظة: مسح ذاكرة التخزين المؤقت آمن تمامًا، فلن يحذف أبدًا مشاريع مستندات الترجمة الخاصة بك أو ملفات المشروع المحفوظة أو ملفات الصوت والفيديو الأصلية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Note: Clearing cache is completely safe. It will never delete your subtitle document projects, saved project files, or original audio/video source files."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注意：キャッシュのクリーンアップは完全に安全です。字幕ドキュメントプロジェクト、保存されたプロジェクトファイル、または元の音声/ビデオソースファイルを削除することは決してありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "참고: 캐시 정리 작업은 완전히 안전합니다. 자막 문서 프로젝트, 저장된 프로젝트 파일 또는 원본 오디오/비디오 소스 파일은 삭제되지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "提示：清理缓存是完全安全的，它绝不会删除您的字幕文稿项目、已保存的工程文件或原始音视频源文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "提示：清理快取是完全安全的，它絕不會刪除您的字幕文稿專案、已儲存的工程檔案或原始音音訊來源檔案。"
          }
        }
      }
    },
    "note_this_model_has_not" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ملاحظة: هذا النموذج لم يتم تنزيله بعد، وسيتم تنزيله تلقائيًا من Hugging Face عند بدء التوليد."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Note: This model has not been downloaded yet. It will be downloaded automatically from Hugging Face when generation starts."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注意：このモデルはまだダウンロードされていません。生成開始時に Hugging Face から自動的にダウンロードされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "참고: 이 모델은 아직 다운로드되지 않았습니다. 생성이 시작될 때 Hugging Face에서 자동으로 다운로드됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "提示：此模型尚未下载，开始生成时会从 Hugging Face 自动下载该模型。"
          }
