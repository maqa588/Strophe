    "coreml_acceleration_for_qwen3_explanation" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تسريع مشفر الصوت CoreML INT8 لنموذج qwen3-asr-0.6b؛ لا تزال نماذج MLX 0.6B/1.7B تعمل بشكل مستقل."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CoreML INT8 audio encoder acceleration for qwen3-asr-0.6b; 0.6B/1.7B MLX models can still run independently."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "qwen3-asr-0.6b用のCoreML INT8オーディオエンコーダーアクセラレーション。0.6B / 1.7B MLXモデルは引き続き独立して実行できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "qwen3-asr-0.6b용 CoreML INT8 오디오 인코더 가속. 0.6B / 1.7B MLX 모델은 계속 독자적으로 실행할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用于 qwen3-asr-0.6b 的 CoreML INT8 音频编码器加速；0.6B/1.7B MLX 模型仍可独立运行。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用於 qwen3-asr-0.6b 的 CoreML INT8 音訊編碼器加速；0.6B/1.7B MLX 模型仍可獨立運行。"
          }
        }
      }
    },
    "coreml_compatibility_explanation" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يدعم مشفر CoreML الحالي qwen3-asr-0.6b فقط؛ تعمل النماذج الأخرى على MLX."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Current CoreML encoder only supports qwen3-asr-0.6b; other models run on MLX."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在のCoreMLエンコーダーはqwen3-asr-0.6bのみをサポートします。その他のモデルはMLXで実行されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 CoreML 인코더는 qwen3-asr-0.6b만 지원합니다. 다른 모델은 MLX에서 실행됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当前 CoreML 编码器仅兼容 qwen3-asr-0.6b；该模型将使用 MLX 独立运行。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當前 CoreML 編碼器僅相容 qwen3-asr-0.6b；該模型將使用 MLX 獨立運行。"
          }
        }
      }
    },
