    "use_the_playhead_as_the" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدام مؤشر الوقت كنقطة تقسيم لتقسيم كتلة الترجمة الحالية إلى كتلتين مستقلتين"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use the playhead as the split point to divide the current subtitle block into two independent blocks"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "時間再生ヘッドを分割点として、現在の字幕ブロックを2つの独立したブロックに分割します"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "재생 헤드를 분할 지점으로 사용하여 현재 자막 블록을 두 개의 독립된 블록으로 분할합니다"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以时间游标为分割点，将游标所在的字幕块拆分为两个独立字幕块"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以時間遊標為分割點，將遊標所在的字幕塊拆分為兩個獨立字幕塊"
          }
        }
      }
    },
