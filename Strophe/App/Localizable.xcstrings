    "1080p 30fps 预估：%@。实际码率仍由 VideoToolbox 和画面复杂度决定。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تقدير 1080p 30 إطارًا في الثانية: %@. لا يزال معدل البت الفعلي محددًا بواسطة VideoToolbox وتعقيد الشاشة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1080p 30fps Estimate: %@. The actual bitrate is still determined by VideoToolbox and frame complexity."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1080p 30fps 予測：%@。実際のビットレートは依然として VideoToolbox と画面の複雑さによって決定されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1080p 30fps 예상: %@. 실제 비트레이트는 여전히 VideoToolbox 및 화면 복잡도에 의해 결정됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1080p 30fps 预估：%@。实际码率仍由 VideoToolbox 和画面复杂度决定。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1080p 30fps 預估：%@。實際碼率仍由 VideoToolbox 和畫面複雜度決定。"
          }
        }
      }
    },
