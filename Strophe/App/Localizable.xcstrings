    "\"%@\" could not be opened.\nPlease replace the media file below." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذر فتح \"%@\".\nيرجى استبدال ملف الوسائط أدناه."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" を開けませんでした。\n下のメディアファイルを置き換えてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\"을(를) 열 수 없습니다.\n아래의 미디어 파일을 교체하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" 无法打开。\n请替换下方的媒体文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" 無法開啟。\n請替換下方的媒體檔案。"
          }
        }
      }
    },
