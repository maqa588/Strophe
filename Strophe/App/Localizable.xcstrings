    "speaker_diarization_aligner_explanation" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يزال تحديد المتحدث يستدعي المحاذي لطوابع زمنية على مستوى الكلمة، ولكن لن يتم تحسين الخط الزمني."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diarization still calls aligner for word-level timestamps, but won't refine timeline."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "話者分離は依然としてワードレベルのタイムスタンプのためにアライナーを呼び出しますが、タイムラインの調整は行いません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "화자 분할은 단어 수준 타임스탬프를 위해 정렬기를 호출하지만 타임라인을 정밀 조정하지는 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "对话人识别仍会调用对齐器生成词级时间戳，但不会额外做时间轴精修。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "對話人識別仍會呼叫對齊器生成詞級時間戳記，但不會額外做時間軸精修。"
          }
        }
      }
    },
